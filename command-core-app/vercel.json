{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/leads/index.ts": {
      "includeFiles": "api/_lib/**"
    },
    "api/leads/[id].ts": {
      "includeFiles": "api/_lib/**"
    },
    "api/health.ts": {
      "includeFiles": "api/_lib/**"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
