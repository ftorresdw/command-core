# Google OAuth client ID (required in production at https://core.digitalweave.tech)
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Shared secret for /api/leads website POST (set on Command Core + Digital Weave)
LEADS_API_SECRET=generate-a-long-random-secret

# Supabase (server-side only — set in Vercel, NOT prefixed with VITE_)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
